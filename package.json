{
  "name": "spotlight",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:dmarc": "node --import ./scripts/test-resolve.mjs --test lib/dmarc/*.test.mts",
    "verify": "tsc --noEmit && eslint . && prettier --check .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seed:demo": "node --env-file=.env.local scripts/seed-demo.mts",
    "sweep:social-orphans": "node --env-file=.env.local scripts/sweep-social-orphans.mts",
    "db:reset": "npx supabase db reset --local && psql postgresql://postgres:postgres@127.0.0.1:55322/postgres -f scripts/local-reset-grants.sql"
  },
